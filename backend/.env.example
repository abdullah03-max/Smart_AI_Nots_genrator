# backend/.env.example — copy to .env and fill in your values

# ── AI Provider (default: groq — free and FAST) ────────────────────────────────
AI_PROVIDER=groq

# 🥇 GROQ — FREE, no credit card, ~10x faster than Gemini
# Get key in 30 seconds: https://console.groq.com → API Keys → Create
GROQ_API_KEY=your_groq_api_key_here

# 🥈 Google Gemini — free but slower (alternative)
# Get key: https://aistudio.google.com/app/apikey

# ── Supabase ────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://fokeuknbaapxbyggjpuv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# ── App ─────────────────────────────────────────────────────────────────────────
DEBUG=false
MAX_UPLOAD_SIZE_MB=10
